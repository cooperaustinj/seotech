{
  "name": "seotech",
  "private": true,
  "workspaces": {
    "catalog": {
      "@types/react": "^19.2.8",
      "@types/react-dom": "^19.2.3",
      "@vitejs/plugin-react": "^5.1.2",
      "oxfmt": "^0.24.0",
      "oxlint": "^1.39.0",
      "react": "^19.2.3",
      "react-dom": "^19.2.3",
      "turbo": "^2.7.4",
      "typescript": "^5.9.3",
      "vite": "^7.3.1"
    },
    "packages": [
      "apps/*",
      "packages/*"
    ]
  },
  "scripts": {
    "build": "turbo run build",
    "check-types": "turbo run check-types",
    "dev": "turbo run dev",
    "deploy:web": "bun run --filter @repo/web deploy",
    "format": "oxfmt . && turbo run format",
    "format:check": "oxfmt --check . && turbo run format:check",
    "lint": "turbo run lint",
    "lint:fix": "turbo run lint:fix",
    "preview": "turbo run preview"
  },
  "devDependencies": {
    "oxfmt": "catalog:",
    "oxlint": "catalog:",
    "turbo": "catalog:",
    "typescript": "catalog:"
  },
  "packageManager": "bun@1.3.6"
}
